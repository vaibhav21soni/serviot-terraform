# Copy to terraform.tfvars (gitignored) and fill in. NEVER commit real values.
# Secrets are better passed as TF_VAR_* env vars than written to any file.

region        = "us-east-1"
admin_ip_cidr = "203.0.113.10/32" # your office/VPN egress IP — locks SSH + Jenkins
# Key pair generated by default (private key -> ./serviot-key.pem, gitignored).
# To reuse an existing one:
# create_key_pair   = false
# existing_key_name = "my-ec2-keypair"

# Two instances (default). Override sizes here if needed.
# instances = {
#   app     = { role = "app",     instance_type = "t3.medium" }
#   jenkins = { role = "jenkins", instance_type = "t3.small" }
# }

# RDS master (or export TF_VAR_master_password)
master_username = "serviot_admin"
# master_password = "set-via-TF_VAR_master_password"

# Backups optional — off by default. Set true for prod.
enable_backups = false

# Per-app DBs: only when Terraform can reach RDS over the network.
manage_databases = false
# app1_db_password = "..."
# app2_db_password = "..."

jenkins_port = 8443
